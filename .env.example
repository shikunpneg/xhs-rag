# 小红书 Cookie (必填)
# 从浏览器开发者工具中获取，格式如：a1=xxx; webId=xxx; ...
XHS_COOKIE=

# DeepSeek API Key (用于 LLM 和 Embedding)
DEEPSEEK_API_KEY=sk-87ca71c098b14a68a12e2b4461bd986a
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 嵌入模型配置
EMBED_MODEL=deepseek-embed
EMBED_DIM=1024

# LLM 模型配置
LLM_MODEL=deepseek-v4-flash

# 向量数据库配置
CHROMA_PERSIST_DIR=./data/chroma

# 数据库配置
DB_PATH=./data/xhs_notes.db
